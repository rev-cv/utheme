HOST_PORT=8081
SITE_URL=http://localhost:${HOST_PORT}
# для установки на сервисах нужно прописывать конечный домен http://domen.com (HTTP, но не HTTPS)
# для дополнения новыми страницами сайта уже размещенного в сети использовать https://domen.com
# URL не должен заканчивать на / (неправильно, https://domen.com/)

THEME_SLUG="utheme"
SITE_TITLE="Site Name"
CONTAINER_NAME="domen-com"
SITE_LANG="EN"
# Поддерживаются два формата:
#   Короткий код языка:   EN, FR, DE, PL, CZ, PT, IT, NL, ES, SK, ET,
#                         LV, RO, SV, LT, BG, SL, HU, FI, DA, RU, GR, HR, NO, LB, GA
#   WP locale (язык+регион): fr_BE, fr_CA, de_AT, de_CH, pt_BR, en_GB, nl_BE ...
#   https://wpastra.com/docs/complete-list-wordpress-locale-codes/
ADMIN_USER="admin"
ADMIN_EMAIL="admin@domen.com"

WP_APP_PASSWORD="JyzitTLMCcU1fsxauO5EUmkl"

# БД сайта — заполняются автоматически при первом запуске setup.py
# Если пустые — генерируются из CONTAINER_NAME
DB_NAME="domen-com"
DB_USER="domen-com"
DB_PASSWORD=""

# Путь к общей MariaDB (по умолчанию ../../wp-marid-db относительно setup.py)
# SHARED_DB_PATH=""

# Лимиты ресурсов контейнера WordPress
WP_CPU_LIMIT=0.5
WP_MEM_LIMIT=256m

SCHEDULE_PATTERN="3d 2-3p (10-21)"
# 3d 2-3p (10-21) - 2 или 3 публикации через каждый три дня с 10 по 21 по времени сервера
# 0d 1p (8-21) - каждый день одна публикация с 8 до 21 по времени сервера