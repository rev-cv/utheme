#!/usr/bin/env bash
# Generated by pipeline — do not edit manually
# Site: {{ site.title }} | {{ site.url }}

wp() { command wp --allow-root "$@"; }

# Patch wp-config.php for HTTPS proxy (Nginx Proxy Manager)
if ! grep -q "HTTP_X_FORWARDED_PROTO" wp-config.php; then
    sed -i "2i // Proxy SSL Fix\nif (isset(\$_SERVER['HTTP_X_FORWARDED_PROTO']) && \$_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') { \$_SERVER['HTTPS'] = 'on'; }\n" wp-config.php
fi

if [ ! -f wp-config.php ]; then
    echo "Error: run this script from the WordPress root directory!"
    exit 1
fi

SITE_URL="{{ site.url }}"
SITE_TITLE="{{ site.title | bash_escape }}"
ADMIN_USER="{{ site.admin_user | bash_escape }}"
ADMIN_EMAIL="{{ site.email }}"
THEME_SLUG="{{ site.theme_slug | default('utheme') }}"
WP_LANG="{{ wp_locale }}"

ADMIN_PASS=$(tr -dc 'a-zA-Z0-9!@#$%^&*()_+=-' < /dev/urandom | head -c 30)

echo "--- WP Auto-Setup: $SITE_TITLE ---"

# ===========================================================================
# 1. INSTALL WORDPRESS

wp core install \
    --url="$SITE_URL" \
    --title="Initial Setup" \
    --admin_user="$ADMIN_USER" \
    --admin_password="$ADMIN_PASS" \
    --admin_email="$ADMIN_EMAIL" \
    --skip-email

wp language core install $WP_LANG --activate
echo "Language set to $WP_LANG."

# Ensure all DB URLs use HTTPS only for real domains, not local Docker
if echo "$SITE_URL" | grep -qE '^http://(localhost|127\.0\.0\.1)(:|/|$)'; then
    echo "Localhost detected. Keeping HTTP."
else
    HTTPS_URL="$(echo "$SITE_URL" | sed 's|^http://|https://|')"
    if [ "$HTTPS_URL" != "$SITE_URL" ]; then
        wp search-replace "$SITE_URL" "$HTTPS_URL" --all-tables --quiet
        SITE_URL="$HTTPS_URL"
        echo "URLs upgraded to HTTPS."
    fi
fi

# ===========================================================================
# 2. ADMIN USER

FIRST_NAME="{{ editorial_first | bash_escape }}"
LAST_NAME="«$SITE_TITLE»"
DISPLAY_NAME="$FIRST_NAME $LAST_NAME"

if wp user get "$ADMIN_USER" > /dev/null 2>&1; then
    wp user update "$ADMIN_USER" \
        --user_pass="$ADMIN_PASS" \
        --role=administrator \
        --display_name="$DISPLAY_NAME" \
        --first_name="$FIRST_NAME" \
        --last_name="$LAST_NAME"
else
    wp user create "$ADMIN_USER" "$ADMIN_EMAIL" \
        --user_pass="$ADMIN_PASS" \
        --role=administrator \
        --display_name="$DISPLAY_NAME" \
        --first_name="$FIRST_NAME" \
        --last_name="$LAST_NAME"
fi

ADMIN_ID=$(wp user get "$ADMIN_USER" --field=ID)
wp user update 1 --locale=en_US
echo "Admin user ready (ID: $ADMIN_ID)."

# ===========================================================================
# 3. THEME

wp theme activate $THEME_SLUG
wp theme list --status=inactive --field=name | while read -r _theme; do wp theme delete "$_theme"; done
echo "Theme '$THEME_SLUG' activated."

# ===========================================================================
# 4. CLEANUP DEFAULT CONTENT

wp post delete $(wp post list --post_type=post,page --format=ids) --force
wp eval "global \$wpdb;
    \$wpdb->query(\"TRUNCATE TABLE {\$wpdb->prefix}posts\");
    \$wpdb->query(\"TRUNCATE TABLE {\$wpdb->prefix}postmeta\");
    \$wpdb->query(\"TRUNCATE TABLE {\$wpdb->prefix}terms\");
    \$wpdb->query(\"TRUNCATE TABLE {\$wpdb->prefix}term_taxonomy\");
    \$wpdb->query(\"TRUNCATE TABLE {\$wpdb->prefix}term_relationships\");"
echo "Default content removed."

# ===========================================================================
# 5. SETTINGS

wp eval "
global \$wp_rewrite;
update_option('blogname', base64_decode('{{ site.title | b64 }}'));
\$wp_rewrite->set_permalink_structure('/%postname%/');
\$wp_rewrite->flush_rules(true);
update_option('default_pingback_flag', 0);
update_option('default_ping_status', 'closed');
update_option('default_comment_status', 'closed');
update_option('require_name_email', 1);
update_option('comment_registration', 1);
update_option('close_comments_for_old_posts', 1);
update_option('thread_comments', 1);
update_option('thread_comments_depth', 5);
update_option('page_comments', 1);
update_option('comments_per_page', 50);
update_option('default_comments_page', 'newest');
update_option('moderation_notify', 0);
update_option('comments_notify', 0);
update_option('comment_moderation', 1);
update_option('comment_whitelist', 1);
update_option('uploads_use_yearmonth_folders', 0);
update_user_meta($ADMIN_ID, 'edit_post_per_page', 200);
update_user_meta($ADMIN_ID, 'edit_page_per_page', 200);
"
echo "Settings applied."

# ===========================================================================
# 6. CATEGORIES

wp eval "
wp_insert_term('Utility Pages', 'category');
wp_insert_term('page+5', 'category');
wp_insert_term('page+30', 'category');
wp_insert_term('news', 'category');
"
echo "Categories created."

# ===========================================================================
# 7. MEDIA IMPORT
# Медиа импортируются ДО создания страниц, чтобы знать attachment ID и URL
# для замены плейсхолдеров %%IMGID:file.webp%% и %%IMGSRC:file.webp%% в .wp файлах

echo "Importing media from /tmp/staging/images/ ..."
declare -A MEDIA_IDS   # filename → attachment_id
declare -A MEDIA_URLS  # filename → public URL

while IFS=$'\t' read -r _f1 _f2 _f3; do
    if [ "$_f1" = "WARN" ]; then
        echo "  WARN: failed to import $_f2"
    else
        MEDIA_IDS["$_f1"]=$_f2
        MEDIA_URLS["$_f1"]=$_f3
        echo "  $_f1 → ID $_f2"
    fi
done < <(wp eval "
ob_start();
require_once ABSPATH . 'wp-admin/includes/media.php';
require_once ABSPATH . 'wp-admin/includes/file.php';
require_once ABSPATH . 'wp-admin/includes/image.php';
\$results = [];
foreach (glob('/tmp/staging/images/*') as \$file) {
    if (!is_file(\$file)) continue;
    \$fname = basename(\$file);
    \$arr   = ['name' => \$fname, 'tmp_name' => \$file];
    \$post_data = ['post_name' => sanitize_title(\$fname)];
    \$id    = media_handle_sideload(\$arr, 0, null, \$post_data);
    if (is_wp_error(\$id)) {
        \$results[] = 'WARN' . chr(9) . \$fname . chr(9) . '';
        continue;
    }
    // Force slug to include extension so it never collides with a page slug
    wp_update_post(['ID' => \$id, 'post_name' => str_replace('.', '-', \$fname)]);
    \$results[] = \$fname . chr(9) . \$id . chr(9) . wp_get_attachment_url(\$id);
}
ob_end_clean();
echo implode(chr(10), \$results) . chr(10);
" 2>/dev/null)

{% if site.favicon %}
if [ -n "${MEDIA_IDS[{{ site.favicon }}]}" ]; then
    wp option update site_icon ${MEDIA_IDS[{{ site.favicon }}]}
    echo "  Favicon set (ID: ${MEDIA_IDS[{{ site.favicon }}]})"
fi
{% endif %}
{% if site.logo %}
if [ -n "${MEDIA_IDS[{{ site.logo }}]}" ]; then
    wp eval "set_theme_mod('custom_logo', ${MEDIA_IDS[{{ site.logo }}]});"
    echo "  Logo set (ID: ${MEDIA_IDS[{{ site.logo }}]})"
fi
{% endif %}

# Заменяем плейсхолдеры в .wp файлах реальными ID и URL
echo "Resolving image placeholders in .wp files..."
for page_file in /tmp/staging/pages/*.wp; do
    [ -f "$page_file" ] || continue
    for fname in "${!MEDIA_IDS[@]}"; do
        img_id=${MEDIA_IDS[$fname]}
        img_url=${MEDIA_URLS[$fname]}
        sed -i "s@%%IMGID:${fname}%%@${img_id}@g" "$page_file"
        sed -i "s@%%IMGSRC:${fname}%%@${img_url}@g" "$page_file"
    done
done
echo "Placeholders resolved."

# Заменяем плейсхолдеры внутренних ссылок %%PAGEURL:slug%% → реальный URL
echo "Resolving internal link placeholders in .wp files..."
for page_file in /tmp/staging/pages/*.wp; do
    [ -f "$page_file" ] || continue
    sed -i -E "s|%%PAGEURL:([^%]+)%%|${SITE_URL}/\1/|g" "$page_file"
done
echo "Internal link placeholders resolved."

# ===========================================================================
# 8. PAGES
# Все страницы создаются в одном PHP-процессе (один бутстрап WP).
# PHP выводит slug→ID сразу после каждой страницы (fflush), bash читает построчно.

# Сериализуем MEDIA_IDS → JSON для передачи в PHP
{
    printf '{'
    _first=1
    for _fname in "${!MEDIA_IDS[@]}"; do
        [ $_first -eq 1 ] && _first=0 || printf ','
        printf '"%s":%s' "$_fname" "${MEDIA_IDS[$_fname]}"
    done
    printf '}'
} > /tmp/media_ids.json

declare -A PAGE_IDS

cat > /tmp/create_pages.php << PHPEOF
<?php
\$admin_id  = $ADMIN_ID;
\$media_ids = json_decode(file_get_contents('/tmp/media_ids.json'), true) ?: [];
\$page_ids  = [];
ob_implicit_flush(true);

\$pages = [
{% for page in pages %}
    [
        'slug'         => '{{ page.slug }}',
        'title'        => '{{ page.title | b64 }}',
        'status'       => '{{ page.post_status if page.post_status else ("publish" if page.publish_at == "now" else "future") }}',
        'date'         => '{{ page.publish_at if (not page.post_status and page.publish_at != "now") else "" }}',
        'content_file' => '{{ ("/tmp/staging/pages/" ~ page.content) if page.content else "" }}',
        'template'     => '{{ page.template }}',
        'parent_slug'  => '{{ page.parent if page.parent else "" }}',
        'cats'         => [{% for cat in (page.categories or []) %}'{{ cat }}'{% if not loop.last %}, {% endif %}{% endfor %}],
        'thumb'        => '{{ page.images[0] if page.images else "" }}',
        'seo_headline' => '{{ page.seo_title | b64 if page.seo_title else "" }}',
        'seo_desc'     => '{{ page.seo_descr | b64 if page.seo_descr else "" }}',
    ],
{% endfor %}
];

foreach (\$pages as \$p) {
    ob_start();
    \$parent_id = \$p['parent_slug'] !== '' ? (\$page_ids[\$p['parent_slug']] ?? 0) : 0;
    \$args = [
        'post_type'     => 'page',
        'post_title'    => base64_decode(\$p['title']),
        'post_name'     => \$p['slug'],
        'post_status'   => \$p['status'],
        'post_content'  => \$p['content_file'] !== '' ? file_get_contents(\$p['content_file']) : '',
        'page_template' => \$p['template'],
        'post_author'   => \$admin_id,
        'post_parent'   => \$parent_id,
    ];
    if (\$p['date'] !== '') \$args['post_date'] = \$p['date'];
    \$id = wp_insert_post(\$args);
    \$page_ids[\$p['slug']] = \$id;
    if (!empty(\$p['cats']))       wp_set_object_terms(\$id, \$p['cats'], 'category', false);
    if (\$p['thumb'] !== '' && isset(\$media_ids[\$p['thumb']])) update_post_meta(\$id, '_thumbnail_id', \$media_ids[\$p['thumb']]);
    \$seo_t = \$p['seo_headline'] !== '' ? base64_decode(\$p['seo_headline']) : base64_decode(\$p['title']);
    update_post_meta(\$id, '_custom_seo_title', \$seo_t);
    if (\$p['seo_headline'] !== '') update_post_meta(\$id, '_custom_seo_headline', base64_decode(\$p['seo_headline']));
    if (\$p['seo_desc']     !== '') update_post_meta(\$id, '_custom_seo_desc',     base64_decode(\$p['seo_desc']));
    ob_end_clean();
    echo \$p['slug'] . "\t" . \$id . "\n";
    fflush(STDOUT);
}
PHPEOF

while IFS=$'\t' read -r _slug _pid; do
    PAGE_IDS[$_slug]=$_pid
    echo "  Created '$_slug' (ID: $_pid)"
done < <(wp eval-file /tmp/create_pages.php 2>/dev/null)
rm -f /tmp/create_pages.php /tmp/media_ids.json

# Homepage and privacy page
if [ -n "${PAGE_IDS[index]}" ]; then
    wp eval "update_option('show_on_front', 'page'); update_option('page_on_front', ${PAGE_IDS[index]});"
fi
if [ -n "${PAGE_IDS[privacy-policy]}" ]; then
    wp eval "update_option('wp_page_for_privacy_policy', ${PAGE_IDS[privacy-policy]});"
fi

# ===========================================================================
# 9. WELCOME NEWS POST

WELCOME_POST_ID=$(wp eval "
ob_start();
\$id = wp_insert_post([
    'post_type'    => 'post',
    'post_title'   => base64_decode('{{ welcome_title | b64 }}'),
    'post_content' => base64_decode('{{ welcome_content | b64 }}'),
    'post_status'  => 'publish',
    'post_author'  => $ADMIN_ID,
]);
wp_set_object_terms(\$id, 'news', 'category', false);
ob_end_clean();
echo \$id;
" 2>/dev/null)
echo "  Created welcome post (ID: $WELCOME_POST_ID)"

# ===========================================================================
# 10. MENUS

{% if menus.main is defined and menus.main %}
wp eval "
\$menu_id = wp_create_nav_menu('MainMenu');
\$locs = get_theme_mod('nav_menu_locations', []);
\$locs['header-menu'] = \$menu_id;
set_theme_mod('nav_menu_locations', \$locs);
{% for node in menus.main %}
\$parent_item_{{ node.slug | replace('-', '_') }} = wp_update_nav_menu_item(\$menu_id, 0, ['menu-item-object-id' => ${PAGE_IDS[{{ node.slug }}]}, 'menu-item-type' => 'post_type', 'menu-item-object' => 'page', 'menu-item-status' => 'publish'{% if node.menu_title %}, 'menu-item-title' => base64_decode('{{ node.menu_title | b64 }}'){% endif %}]);
{% if node.children is defined and node.children %}
{% for child in node.children %}
wp_update_nav_menu_item(\$menu_id, 0, ['menu-item-object-id' => ${PAGE_IDS[{{ child.slug }}]}, 'menu-item-type' => 'post_type', 'menu-item-object' => 'page', 'menu-item-status' => 'publish', 'menu-item-parent-id' => \$parent_item_{{ node.slug | replace('-', '_') }}{% if child.menu_title is defined and child.menu_title %}, 'menu-item-title' => base64_decode('{{ child.menu_title | b64 }}'){% endif %}]);
{% endfor %}
{% endif %}
{% endfor %}
"
echo "MainMenu created with {{ menus.main | length }} items."
{% endif %}

{% if menus.footer is defined and menus.footer %}
wp eval "
\$menu_id = wp_create_nav_menu('FooterMenu');
\$locs = get_theme_mod('nav_menu_locations', []);
\$locs['footer-menu'] = \$menu_id;
set_theme_mod('nav_menu_locations', \$locs);
{% for node in menus.footer %}
wp_update_nav_menu_item(\$menu_id, 0, ['menu-item-object-id' => ${PAGE_IDS[{{ node.slug }}]}, 'menu-item-type' => 'post_type', 'menu-item-object' => 'page', 'menu-item-status' => 'publish']);
{% endfor %}
"
echo "FooterMenu created with {{ menus.footer | length }} items."
{% endif %}

# ===========================================================================
# 11. PLUGINS

wp plugin delete hello dolly
wp plugin delete akismet
echo "Default plugins removed."

# ===========================================================================
# 12. APPLICATION PASSWORD

APP_PASS=$(wp user application-password create $ADMIN_USER "autoposter" --porcelain)

echo ""
echo "========================================================="
echo "  CREDENTIALS (copy now!)"
echo "  URL:      $SITE_URL"
echo "  Login:    $ADMIN_USER"
echo "  Password: $ADMIN_PASS"
echo "  Email:    $ADMIN_EMAIL"
echo "  App Pass: $APP_PASS"
echo "========================================================="
echo ""

mkdir -p wp-content/uploads
printf '{\n  "admin_user": "%s",\n  "admin_pass": "%s",\n  "admin_email": "%s",\n  "app_pass": "%s"\n}\n' \
    "$ADMIN_USER" "$ADMIN_PASS" "$ADMIN_EMAIL" "$APP_PASS" \
    > wp-content/uploads/temp_wp.json
echo "Credentials saved to wp-content/uploads/temp_wp.json"
echo "--- Done ---"
